rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Worksheets: teacher writes, authenticated users read
    match /worksheets/{worksheetId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.role == 'teacher';
    }

    // Submissions: owning student writes (max 25 MB), teacher reads all
    match /submissions/{submissionId}/{fileName} {
      allow read: if request.auth != null
        && (request.auth.token.role == 'teacher'
            || request.auth.uid == submissionId.split('_')[0]);
      allow create: if request.auth != null
        && request.auth.token.role == 'student'
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf');
      allow delete: if request.auth != null
        && request.auth.token.role == 'teacher';
    }
  }
}
